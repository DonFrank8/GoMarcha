# GoMarcha Backup — Environment Template
# -----------------------------------------
# Copy this file to .env.backup.local and fill in your real values.
# .env.backup.local is gitignored and must NEVER be committed.
#
#   cp .env.backup.example .env.backup.local
#

# Supabase project URL (public, no secret)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service Role Key — full DB access, bypasses RLS.
# Find it in: Supabase Dashboard → Settings → API → service_role key
# Store the real value only in your password manager.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Local output directory for backup folders (relative to project root or absolute).
# Default: ./backups
BACKUP_OUTPUT_DIR=./backups

# Create a ZIP archive of each backup folder after export? (true / false)
# Default: true
BACKUP_CREATE_ZIP=true

# Optional: keep raw backup folder after ZIP is created? (true / false)
# Default: false — folder is removed after ZIP to save space
BACKUP_KEEP_FOLDER_AFTER_ZIP=false
